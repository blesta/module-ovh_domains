<?php /** @var View $this **/ ?>

<h6 class="form-section-header first"><?php $this->_('OvhDomains.tab_nameservers.heading');?></h6>
<?php
    $this->Form->create();
    ?>
<div>
    <?php

            foreach ($nameserver_fields ?? [] as $name => $field) {
                ?>
    <div class="mb-3">
    <?php

                    $this->Form->label($field['label'], $name, ['class' => 'form-label']);
                    $this->Form->fieldText($name, ($vars->{$name} ?? ''), ['id' => $name, 'class' => 'form-control']);
                    ?>
    </div>
    <?php
            }
            ?>
</div>
<div class="d-flex justify-content-end">
    <?php

        $this->Form->fieldSubmit(null, $this->_('OvhDomains.tab_nameservers.field_submit', true), ['class' => 'btn btn-primary']);
        ?>
</div>
<?php
    $this->Form->end();
    ?>
